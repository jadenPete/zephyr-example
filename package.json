{
  "name": "zephyr-example",
  "devDependencies": {
    "@module-federation/vite": "^1.11.0",
    "@tailwindcss/vite": "^4.2.1",
    "@tsconfig/strictest": "^2.0.8",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3",
